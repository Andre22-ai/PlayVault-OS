<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #0b0114; -fx-border-color: #00ffff; -fx-border-width: 4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.progetto.DettagliGiocoController">
   <children>
      <Button layoutX="30.0" layoutY="30.0" mnemonicParsing="false" onAction="#tornaAllaDashboard" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #000000; -fx-border-color: #ff00ff; -fx-border-width: 2; -fx-border-radius: 20; -fx-background-radius: 20; -fx-text-fill: #ff00ff; -fx-cursor: hand;" text="&lt; BACK" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0">
         <font><Font name="Consolas Bold" size="16.0" /></font>
         <effect><DropShadow color="#ff00ff" radius="10.0" spread="0.2" /></effect>
      </Button>

      <HBox spacing="50.0" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="80.0" AnchorPane.topAnchor="100.0">
         <children>
            <VBox alignment="CENTER" prefWidth="300.0" style="-fx-background-color: #002b2b; -fx-border-color: #00ffff; -fx-border-width: 3; -fx-border-radius: 10;">
               <children>
                  <Label fx:id="coverLabel" text="TITLE" textFill="#00ffff" wrapText="true" alignment="CENTER" textAlignment="CENTER">
                     <font><Font name="System Bold" size="48.0" /></font>
                  </Label>
               </children>
               <effect><DropShadow color="#00ffff" radius="20.0" spread="0.1" /></effect>
            </VBox>

            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label fx:id="idLabel" text="[ID: ???]" textFill="#888888" wrapText="true">
                     <font><Font name="Consolas" size="12.0" /></font>
                  </Label>
                  
                  <Label fx:id="titoloLabel" text="GAME TITLE" textFill="#39ff14" wrapText="true">
                     <font><Font name="Consolas Bold" size="40.0" /></font>
                     <effect><DropShadow color="#39ff14" radius="10.0" spread="0.2" /></effect>
                  </Label>
                  
                  <VBox spacing="5.0">
                     <Label fx:id="devAnnoLabel" text="STUDIO: ??? // RELEASE: ????" textFill="#ff00ff">
                        <font><Font name="Consolas" size="18.0" /></font>
                     </Label>
                     <Label fx:id="genereLabel" text="CLASS: ???" textFill="#ff00ff">
                        <font><Font name="Consolas" size="18.0" /></font>
                     </Label>
                  </VBox>

                  <Label text="LORE / SYSTEM LOGS:" textFill="#00ffff">
                     <font><Font name="Consolas Bold" size="14.0" /></font>
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </Label>
                  
                  <TextArea fx:id="descArea" editable="false" style="-fx-control-inner-background: #000000; -fx-background-color: transparent; -fx-border-color: #00ffff; -fx-text-fill: #00ffff; -fx-font-family: Consolas; -fx-font-size: 16px;" wrapText="true" VBox.vgrow="ALWAYS" />
                  
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#eseguiAcquisto" prefHeight="60.0" minHeight="60.0" style="-fx-background-color: #39ff14; -fx-text-fill: #000000; -fx-background-radius: 10; -fx-border-radius: 10; -fx-cursor: hand;" text="INITIALIZE GAME ENGINE">
                     <font><Font name="Consolas Bold" size="20.0" /></font>
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                     <effect><DropShadow color="#39ff14" radius="15.0" spread="0.3" /></effect>
                  </Button>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>