<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #0b0114; -fx-border-color: #00ffff; -fx-border-width: 4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.progetto.boundary.ImpostazioniControllerFX">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #0d0012; -fx-border-color: #00ffff; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;">
         <BorderPane.margin>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </BorderPane.margin>
         <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
         </padding>
         <children>
            <Button fx:id="backButton" mnemonicParsing="false" onAction="#tornaAllaDashboard" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #000000; -fx-border-color: #ff00ff; -fx-border-width: 2; -fx-border-radius: 20; -fx-background-radius: 20; -fx-text-fill: #ff00ff; -fx-cursor: hand;" text="BACK">
               <font>
                  <Font name="Consolas Bold" size="14.0" />
               </font>
               <effect>
                  <DropShadow color="#ff00ff" radius="10.0" spread="0.2" />
               </effect>
            </Button>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="titleLabel" text="SYSTEM SETTINGS" textFill="#ffea00">
               <font>
                  <Font name="Consolas Bold" size="28.0" />
               </font>
               <effect>
                  <DropShadow color="#ff8800" radius="6.0" spread="0.2" />
               </effect>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Region prefWidth="180.0" />
         </children>
      </HBox>
   </top>
   <center>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 24;">
         <children>
            <VBox spacing="12.0" style="-fx-background-color: #1a0033; -fx-padding: 16; -fx-border-color: #00ffff; -fx-border-radius: 10; -fx-background-radius: 10;">
               <children>
                  <Label fx:id="languageLabel" text="LANGUAGE" textFill="#00ffff">
                     <font>
                        <Font name="Consolas Bold" size="16.0" />
                     </font>
                  </Label>
                  <HBox spacing="15.0">
                     <children>
                        <Button fx:id="italianoButton" mnemonicParsing="false" onAction="#selezionaItaliano" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #000000; -fx-border-color: #00ffff; -fx-border-width: 2; -fx-border-radius: 20; -fx-background-radius: 20; -fx-text-fill: #00ffff; -fx-cursor: hand;" text="ITALIANO" />
                        <Button fx:id="englishButton" mnemonicParsing="false" onAction="#selezionaEnglish" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #000000; -fx-border-color: #39ff14; -fx-border-width: 2; -fx-border-radius: 20; -fx-background-radius: 20; -fx-text-fill: #39ff14; -fx-cursor: hand;" text="ENGLISH" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox spacing="12.0" style="-fx-background-color: #1a0033; -fx-padding: 16; -fx-border-color: #ffea00; -fx-border-radius: 10; -fx-background-radius: 10;">
               <children>
                  <Label fx:id="securityLabel" text="SECURITY" textFill="#ffea00">
                     <font>
                        <Font name="Consolas Bold" size="16.0" />
                     </font>
                  </Label>
                  <PasswordField fx:id="nuovaPasswordField" prefHeight="40.0" promptText="New password" style="-fx-background-color: #000000; -fx-border-color: #ffea00; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #ffea00;" />
                  <Button fx:id="passwordButton" mnemonicParsing="false" onAction="#aggiornaPassword" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #ffea00; -fx-text-fill: #000000; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand;" text="CHANGE PASSWORD" />
               </children>
            </VBox>

            <VBox spacing="12.0" style="-fx-background-color: #1a0033; -fx-padding: 16; -fx-border-color: #ff0040; -fx-border-radius: 10; -fx-background-radius: 10;">
               <children>
                  <Label fx:id="dangerLabel" text="DANGER ZONE" textFill="#ff0040">
                     <font>
                        <Font name="Consolas Bold" size="16.0" />
                     </font>
                  </Label>
                  <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#eliminaAccount" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #ff0040; -fx-text-fill: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand;" text="DELETE ACCOUNT" />
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
