<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="280.0" prefWidth="200.0" spacing="15.0" styleClass="card-base, card-ciano" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.progetto.boundary.CardNegozioController">
   <padding>
      <Insets bottom="15.0" left="10.0" right="10.0" top="15.0" />
   </padding>

   <Label fx:id="idLbl" styleClass="testo-id" text="[ID: 0]">
      <VBox.margin><Insets bottom="-10.0" /></VBox.margin>
   </Label>

   <Label fx:id="titoloLbl" styleClass="testo-titolo-ciano" text="TITOLO" />

   <VBox alignment="CENTER" prefHeight="120.0" prefWidth="160.0" styleClass="cover-ciano">
      <Label fx:id="coverTesto" styleClass="testo-titolo-ciano" text="COV">
         <font><Font size="24.0" /></font>
      </Label>
   </VBox>

   <Region VBox.vgrow="ALWAYS" />

   <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#apriDettagliAcquisto" prefHeight="35.0" styleClass="btn-outline-ciano" text="INFO / BUY">
      <VBox.margin><Insets bottom="5.0" left="10.0" right="10.0" /></VBox.margin>
   </Button>
</VBox>