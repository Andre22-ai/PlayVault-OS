<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="300.0" spacing="10.0" styleClass="card-base, card-gialla" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.progetto.boundary.CardRecensioneController">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>

   <Label fx:id="gameLbl" styleClass="testo-titolo-ciano" text="TARGET: Gioco" />
   
   <Label fx:id="ratingLbl" styleClass="testo-titolo-giallo" text="RATING: ★★★☆☆" />
   
   <Label fx:id="logLbl" styleClass="testo-descrizione" style="-fx-text-fill: #39ff14;" text="LOG: Commento..." wrapText="true" />
   
   <HBox alignment="CENTER_RIGHT" spacing="15.0">
      <VBox.margin><Insets top="10.0" /></VBox.margin>
      <Button mnemonicParsing="false" onAction="#modificaRecensione" styleClass="btn-outline-ciano" text="EDIT" />
      <Button mnemonicParsing="false" onAction="#eliminaRecensione" styleClass="btn-outline-rosso" text="DELETE" />
   </HBox>
</VBox>