<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #1a0524;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.progetto.DashboardController">
   
   <top>
      <HBox alignment="CENTER" prefHeight="80.0" spacing="20.0" style="-fx-background-color: #0d0012; -fx-border-color: #00ffff; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>
         <children>
            <Label fx:id="creditsLabel" alignment="CENTER" prefHeight="40.0" prefWidth="150.0" style="-fx-border-color: #39ff14; -fx-border-width: 2; -fx-border-radius: 20; -fx-text-fill: #39ff14; -fx-background-color: #000000; -fx-background-radius: 20;" text="CREDITS: --">
               <font>
                  <Font name="Consolas Bold" size="16.0" />
               </font>
               <effect>
                  <DropShadow color="#39ff14" radius="10.0" spread="0.2" />
               </effect>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Label text="PLAYVAULT" style="-fx-text-fill: linear-gradient(to bottom, #ffffff 0%, #ffcc00 40%, #ff8800 100%);">
               <font>
                  <Font name="System Bold" size="42.0" />
               </font>
               <effect>
                  <DropShadow color="#990066" offsetX="5.0" offsetY="5.0" radius="0.0" spread="1.0" />
               </effect>
            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Button mnemonicParsing="false" onAction="#esciDalGioco" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #000000; -fx-border-color: #ff00ff; -fx-border-width: 2; -fx-border-radius: 20; -fx-background-radius: 20; -fx-text-fill: #ff00ff; -fx-font-weight: bold; -fx-cursor: hand;" text="EJECT (LOGOUT)">
               <font>
                  <Font name="Consolas Bold" size="14.0" />
               </font>
               <effect>
                  <DropShadow color="#ff00ff" radius="10.0" spread="0.2" />
               </effect>
            </Button>
         </children>
      </HBox>
   </top>

   <left>
      <VBox alignment="TOP_CENTER" prefWidth="220.0" spacing="20.0" style="-fx-background-color: #0d0012; -fx-border-color: #00ffff; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="5.0" />
         </BorderPane.margin>
         <padding>
            <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
         </padding>
         <children>
            <Label fx:id="playerLabel" text="PLAYER" textFill="#00ffff">
               <font>
                  <Font name="Consolas Bold" size="22.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
               <effect>
                  <DropShadow color="#00ffff" radius="10.0" spread="0.3" />
               </effect>
            </Label>
            
            <Button fx:id="libraryButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#apriLibreria" prefHeight="60.0" style="-fx-background-color: #000000; -fx-border-color: #39ff14; -fx-border-width: 2; -fx-text-fill: #39ff14; -fx-background-radius: 10; -fx-border-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="MY LIBRARY">
               <font>
                  <Font name="Consolas Bold" size="16.0" />
               </font>
            </Button>
            
            <Button fx:id="catalogButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#apriCatalogoAcquisti" prefHeight="60.0" style="-fx-background-color: #000000; -fx-border-color: #39ff14; -fx-border-width: 2; -fx-text-fill: #39ff14; -fx-background-radius: 10; -fx-border-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="ADD GAME">
               <font>
                  <Font name="Consolas Bold" size="16.0" />
               </font>
            </Button>
            
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#vaiAllaHallOfFame" prefHeight="60.0" style="-fx-background-color: #000000; -fx-border-color: #39ff14; -fx-border-width: 2; -fx-text-fill: #39ff14; -fx-background-radius: 10; -fx-border-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="HALL OF FAME">
               <font>
                  <Font name="Consolas Bold" size="16.0" />
               </font>
            </Button>
            
            <Button fx:id="reviewsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#apriMieRecensioni" prefHeight="60.0" style="-fx-background-color: #000000; -fx-border-color: #ffea00; -fx-border-width: 2; -fx-text-fill: #ffea00; -fx-background-radius: 10; -fx-border-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="MY REVIEWS">
               <font>
                  <Font name="Consolas Bold" size="16.0" />
               </font>
            </Button>
            
            <Button fx:id="settingsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#apriImpostazioni" prefHeight="60.0" style="-fx-background-color: #000000; -fx-border-color: #00ffff; -fx-border-width: 2; -fx-text-fill: #00ffff; -fx-background-radius: 10; -fx-border-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="SETTINGS">
               <font>
                  <Font name="Consolas Bold" size="16.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </left>

   <center>
      <VBox style="-fx-background-color: #0d0012; -fx-border-color: #ff00ff; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="10.0" left="5.0" right="10.0" />
         </BorderPane.margin>
         <children>
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="catalogoPane" hgap="30.0" vgap="30.0">
                     <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>